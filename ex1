<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Cadastro de Participantes</title>
</head>
<body>

    <form action="/processar-cadastro" method="POST">
        
        <label for="nome">Nome:</label><br>
        <input type="text" id="nome" name="nome" required>
        <br><br>

        <label for="email">E-mail:</label><br>
        <input type="email" id="email" name="email" required>
        <br><br>

        <label for="telefone">Telefone:</label><br>
        <input type="tel" id="telefone" name="telefone" required>
        <br><br>

        <label for="cpf">CPF:</label><br>
        <input type="text" id="cpf" name="cpf" required>
        <br><br>

        <label for="funcao">Função no projeto:</label><br>
        <input type="text" id="funcao" name="funcao" required>
        <br><br>

        <label for="area">Área de atuação:</label><br>
        <select id="area" name="area" required>
            <option value="" disabled selected>Selecione uma opção</option>
            <option value="lideranca">Liderança</option>
            <option value="colaborador">Colaborador</option>
            <option value="voluntario">Voluntário</option>
        </select>
        <br><br>

        <button type="submit">Cadastrar</button>

    </form>
