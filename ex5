<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Agendamento de Reunião</title>
</head>
<body>

    <div class="container">
        <div class="content-card">
            <h2>Agendamento de Reunião</h2>

            <form action="/agendar-reuniao" method="POST">

                <div class="form-group">
                    <label for="projeto_id">Projeto Relacionado:</label>
                    <select id="projeto_id" name="projeto_id" required>
                        <option value="">Selecione o projeto...</option>
                        <option value="1">Projeto Alfa</option>
                        <option value="2">Projeto Beta</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="pauta">Pauta da Reunião:</label>
                    <input type="text" id="pauta" name="pauta" required>
                </div>

                <div class="form-group">
                    <label for="data_hora">Data e Horário:</label>
                    <input type="datetime-local" id="data_hora" name="data_hora" required>
                </div>

                <div class="form-group">
                    <label for="local_link">Local ou Link de Acesso:</label>
                    <input type="text" id="local_link" name="local_link" placeholder="Sala 01 ou meet.google.com/...">
                </div>

                <div class="form-group">
                    <label>Participantes Convocados:</label>
                    <div style="padding-top: 5px;">
                        <label style="font-weight: normal;">
                            <input type="checkbox" name="participante" value="1"> Participante 1
                        </label>
                        <br>
                        <label style="font-weight: normal;">
                            <input type="checkbox" name="participante" value="2"> Participante 2
                        </label>
                        <br>
                        <label style="font-weight: normal;">
                            <input type="checkbox" name="participante" value="3"> Participante 3
                        </label>
                    </div>
                </div>

                <div class="form-group">
                    <label for="anotacoes">Anotações Prévias:</label>
                    <textarea id="anotacoes" name="anotacoes" rows="5"></textarea>
                </div>

                <input type="submit" value="Agendar Reunião" class="btn-primary">

            </form>
        </div>
    </div>

</body>
</html>
