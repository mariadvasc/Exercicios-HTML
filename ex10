<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Cadastro de Evento Externo</title>
</head>
<body>

    <form action="/cadastrar-evento" method="POST">

        Nome do Evento:
        <br>
        <input type="text" name="nome_evento" required size="40">

        <br><br>

        Tipo de Evento:
        <br>
        <select name="tipo_evento" required>
            <option value="">Selecione...</option>
            <option value="workshop">Workshop</option>
            <option value="palestra">Palestra</option>
            <option value="oficina">Oficina</option>
        </select>

        <br><br>

        Projeto Associado:
        <br>
        <select name="projeto_id" required>
            <option value="">Selecione o projeto...</option>
            <option value="1">Projeto A</option>
            <option value="2">Projeto B</option>
        </select>

        <br><br>

        Data do Evento:
        <br>
        <input type="date" name="data_evento" required>

        <br><br>

        Local:
        <br>
        <input type="text" name="local_evento" placeholder="Endereço ou plataforma online" size="40" required>

        <br><br>

        Público-Alvo:
        <br>
        <input type="text" name="publico_alvo" placeholder="Ex: Estudantes, Comunidade local" size="40">

        <br><br>

        Descrição Curta do Evento:
        <br>
        <textarea name="descricao_evento" rows="4" cols="40"></textarea>

        <br><br>

        <input type="submit" value="Cadastrar Evento">

    </form>

</body>
</html>
