<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Relatórios Personalizados</title>
</head>
<body>

    <div class="container">
        <div class="content-card">
            <h2>Relatórios Personalizados</h2>

            <form action="/gerar-relatorio" method="GET">

                <div class="form-group">
                    <label for="tipo_relatorio">Tipo de Relatório:</label>
                    <select id="tipo_relatorio" name="tipo_relatorio" required>
                        <option value="">Selecione o tipo...</option>
                        <option value="progresso">Relatório de Progresso</option>
                        <option value="participacao">Relatório de Participação</option>
                        <option value="entregas">Relatório de Entregas</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="projeto_id">Projeto Correspondente:</label>
                    <select id="projeto_id" name="projeto_id" required>
                        <option value="">Selecione o projeto...</option>
                        <option value="1">Projeto A</option>
                        <option value="2">Projeto B</option>
                        <option value="3">Projeto C</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="data_inicio">Período Inicial:</label>
                    <input type="date" id="data_inicio" name="data_inicio" required>
                </div>

                <div class="form-group">
                    <label for="data_fim">Período Final:</label>
                    <input type="date" id="data_fim" name="data_fim" required>
                </div>

                <div class="form-group">
                    <label for="notas_relatorio">Observações Adicionais:</label>
                    <textarea id="notas_relatorio" name="notas_relatorio" rows="4"></textarea>
                </div>

                <div class="form-group">
                    <label>Formato de Saída:</label>
                    <div style="padding-top: 5px;">
                        <label style="font-weight: normal; margin-right: 15px;">
                            <input type="radio" name="formato" value="pdf" checked> PDF
                        </label>
                        <label style="font-weight: normal;">
                            <input type="radio" name="formato" value="planilha"> Planilha
                        </label>
                    </div>
                </div>

                <input type="submit" value="Gerar Relatório" class="btn-primary">

            </form>
        </div>
    </div>

</body>
</html>
