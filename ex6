<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registro de Presença</title>
</head>
<body>

    <div class="container">
        <div class="content-card">
            <h2>Registro de Presença</h2>

            <form action="/registrar-presenca" method="POST">

                <div class="form-group">
                    <label for="evento_id">Evento ou Reunião Agendada:</label>
                    <select id="evento_id" name="evento_id" required>
                        <option value="">Selecione o evento...</option>
                        <option value="1">Reunião de Planejamento - 26/03</option>
                        <option value="2">Workshop de Alinhamento - 28/03</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="local_realizado">Local Realizado:</label>
                    <input type="text" id="local_realizado" name="local_realizado" placeholder="Sala ou Link" required>
                </div>

                <p><strong>Lista de Chamada e Justificativas:</strong></p>
                <br>

                <!-- Participante 1 -->
                <div class="form-group" style="border-bottom: 1px solid #eee; padding-bottom: 15px;">
                    <label>
                        <input type="checkbox" name="p1_presente" value="sim"> Participante 1 (Presente)
                    </label>
                    <label for="p1_justificativa" style="font-weight: normal; font-size: 0.85rem;">Justificativa se ausente:</label>
                    <input type="text" id="p1_justificativa" name="p1_justificativa">
                </div>

                <!-- Participante 2 -->
                <div class="form-group" style="border-bottom: 1px solid #eee; padding-bottom: 15px;">
                    <label>
                        <input type="checkbox" name="p2_presente" value="sim"> Participante 2 (Presente)
                    </label>
                    <label for="p2_justificativa" style="font-weight: normal; font-size: 0.85rem;">Justificativa se ausente:</label>
                    <input type="text" id="p2_justificativa" name="p2_justificativa">
                </div>

                <!-- Participante 3 -->
                <div class="form-group" style="border-bottom: 1px solid #eee; padding-bottom: 15px;">
                    <label>
                        <input type="checkbox" name="p3_presente" value="sim"> Participante 3 (Presente)
                    </label>
                    <label for="p3_justificativa" style="font-weight: normal; font-size: 0.85rem;">Justificativa se ausente:</label>
                    <input type="text" id="p3_justificativa" name="p3_justificativa">
                </div>

                <div class="form-group">
                    <label for="notas_presenca">Observações Gerais:</label>
                    <textarea id="notas_presenca" name="notas_presenca" rows="4"></textarea>
                </div>

                <input type="submit" value="Salvar Presença" class="btn-primary">

            </form>
        </div>
    </div>

</body>
</html>
